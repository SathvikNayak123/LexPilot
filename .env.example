# FinDocs Environment Configuration
# Copy to .env and fill in your values

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# Infrastructure
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=findocs
POSTGRES_URL=postgresql+asyncpg://findocs:findocs@localhost:5432/findocs
REDIS_URL=redis://localhost:6379

# Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxx
LANGFUSE_HOST=http://localhost:3000

# HuggingFace
HF_TOKEN=hf_xxxxxxxxxxxxx
HF_MODEL_REPO=your-username/findocs-phi3-finetuned

# Models
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
FINETUNED_MODEL_PATH=./models/phi3-findocs-adapter
FALLBACK_MODEL=gpt-4o-mini
BASE_MODEL_FOR_FINETUNING=microsoft/Phi-3-mini-4k-instruct

# Chunking
CHUNK_SIZE_TOKENS=512
CHILD_CHUNK_SIZE_TOKENS=128
CHUNK_OVERLAP_TOKENS=50

# Retrieval
DENSE_TOP_K=20
SPARSE_TOP_K=20
RERANK_TOP_K=5

# Evaluation thresholds (CI gate)
MIN_FAITHFULNESS=0.80
MIN_CONTEXT_PRECISION=0.70
MIN_ANSWER_RELEVANCE=0.75

# Monitoring
DRIFT_ALERT_THRESHOLD_PCT=5.0
WEEKLY_EVAL_QUESTION_SAMPLE=50

# Slack (for drift alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
