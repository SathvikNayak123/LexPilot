# LLM Providers
OPENROUTER_API_KEY=your_openrouter_key_here
AGENT_MODEL=google/gemini-3-flash-preview

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=lexpilot_chunks

# Knowledge Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=lexpilot

# Infrastructure
POSTGRES_URL=postgresql+asyncpg://lexpilot:lexpilot@localhost:5432/lexpilot
REDIS_URL=redis://localhost:6379/0

# Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# Embedding
EMBEDDING_MODEL=all-mpnet-base-v2
EMBEDDING_DIM=768

# General
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PORT=8000
